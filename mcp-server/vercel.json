{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "echo no-build-needed",
  "framework": null,
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex"
        }
      ]
    }
  ],
  "outputDirectory": "public"
}
